generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── FESTIVAL ────────────────────────────────────────────────────────────────

model Room {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  name       String?
  night      Int?
  created_at DateTime @default(now())

  members  RoomMember[]
  comments Comment[]
}

model RoomMember {
  id         Int      @id @default(autoincrement())
  room_id    Int
  profile_id Int
  isHost     Boolean  @default(false)
  userToken  String   @unique @default(uuid())
  joined_at  DateTime @default(now())

  room    Room    @relation(fields: [room_id], references: [id])
  profile Profile @relation(fields: [profile_id], references: [id])

  @@unique([room_id, profile_id])
}

// ─── UTENTI ──────────────────────────────────────────────────────────────────

model Profile {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  pin        String
  approved   Boolean  @default(false)
  created_at DateTime @default(now())

  rooms     RoomMember[]
  votes     Vote[]
  reactions Reaction[]
  comments  Comment[]
}

// ─── CANZONI ─────────────────────────────────────────────────────────────────

model Song {
  id               Int      @id @default(autoincrement())
  title            String
  artist           String
  artist_canonical String?
  image_url        String?
  created_at       DateTime @default(now())

  performances         SongPerformance[]
  votes                Vote[]
  reactions            Reaction[]
  comments             Comment[]
  festivalStatuses     FestivalStatus[] @relation("CurrentSong")
  lastFestivalStatuses FestivalStatus[] @relation("LastSong")
}

model SongPerformance {
  id               Int       @id @default(autoincrement())
  song_id          Int
  night            Int
  performance_time DateTime?
  performed        Boolean   @default(false)

  song Song @relation(fields: [song_id], references: [id])

  @@unique([song_id, night])
}

// ─── VOTI ────────────────────────────────────────────────────────────────────

model Vote {
  id         Int      @id @default(autoincrement())
  value      Float
  profile_id Int
  song_id    Int
  night      Int
  created_at DateTime @default(now())

  profile Profile @relation(fields: [profile_id], references: [id])
  song    Song    @relation(fields: [song_id], references: [id])

  @@unique([profile_id, song_id, night])
}

// ─── REACTIONS ───────────────────────────────────────────────────────────────

model Reaction {
  id         Int      @id @default(autoincrement())
  type       String
  profile_id Int
  song_id    Int
  created_at DateTime @default(now())

  profile Profile @relation(fields: [profile_id], references: [id])
  song    Song    @relation(fields: [song_id], references: [id])
}

// ─── COMMENTI ────────────────────────────────────────────────────────────────

model Comment {
  id         Int      @id @default(autoincrement())
  text       String
  profile_id Int
  song_id    Int
  room_id    Int
  likes      Int      @default(0)
  dislikes   Int      @default(0)
  created_at DateTime @default(now())

  profile Profile @relation(fields: [profile_id], references: [id])
  song    Song    @relation(fields: [song_id], references: [id])
  room    Room    @relation(fields: [room_id], references: [id])
}

// ─── STATO FESTIVAL ──────────────────────────────────────────────────────────

model FestivalStatus {
  id              Int      @id @default(1)
  type            String
  songId          Int?
  lastSongId      Int?
  eventIndex      Int      @default(0)
  classificaIndex Int?     @default(0)
  updatedAt       DateTime @updatedAt

  // ── AI Commento condiviso ──
  aiTesto         String?
  aiCommentoAt    DateTime?   // timestamp dell'ultimo commento generato

  song     Song? @relation("CurrentSong", fields: [songId], references: [id])
  lastSong Song? @relation("LastSong", fields: [lastSongId], references: [id])
}